# =============================================================================
# .gitignore — Magic Folder (com.mmg.manahub)
# Android MTG Companion App
#
# SECURITY POLICY:
# This file protects credentials, API keys, user data, and build artifacts
# from being accidentally committed to version control.
# Review and update this file whenever new sensitive file types are introduced.
#
# Last reviewed: 2026-04-12
# Audit baseline documented in: .claude/agent-memory/android-security-auditor/
# =============================================================================


# =============================================================================
# SECTION 1 — CREDENTIALS & SECRETS (CRITICAL — NEVER COMMIT)
#
# Committing any of these files exposes API keys, signing credentials, or
# Firebase project configuration to anyone with repository access.
# Store secrets in local.properties (SDK paths + API keys) and never push it.
# In CI, inject secrets via environment variables or a secret manager.
# =============================================================================

# Local build properties: contains YOUTUBE_API_KEY and local SDK path.
# Each developer maintains their own copy. Injected via BuildConfig in build.gradle.kts.
local.properties

# Additional secrets files (signing passwords, third-party keys).
secrets.properties
key.properties

# Firebase configuration: contains project ID, API keys, and OAuth client IDs.
# Exposure allows quota exhaustion and unauthorized Firebase project access.
# In CI, inject the file at build time from a secret manager — do not commit.
google-services.json
app/google-services.json

# Apple/iOS Firebase equivalent (included for cross-platform repo safety).
GoogleService-Info.plist

# Android signing keystores: contain the private key used to sign release APKs.
# Exposure allows an attacker to publish malicious updates under your identity.
*.jks
*.keystore
*.p12
*.pfx

# Generic secret and environment variable files.
.env
.env.*
*.secret
*.secrets


# =============================================================================
# SECTION 2 — ANDROID BUILD ARTIFACTS
#
# Generated by the Gradle build system on every compile. These are fully
# reproducible from source and bloat the repository with binary files that
# cause spurious merge conflicts and slow clone times.
# =============================================================================

# Root-level build directory (Gradle metadata, daemon logs, build cache).
/build/

# Module-level build directories (APKs, AARs, DEX files, R classes, intermediates).
app/build/
**/build/

# Gradle wrapper cache and daemon state (machine-specific).
.gradle/

# External native build artifacts (CMake, ndk-build).
.externalNativeBuild/
.cxx/

# Compiled native shared libraries not checked into the repo.
*.so

# APK and AAB release artifacts.
# Distribute via Google Play Console or CI artifact storage — not git.
*.apk
*.aab

# ProGuard/R8 mapping files for release builds.
# These make reverse-engineering your obfuscated release trivial.
# Store them securely in Play Console or a private artifact store for deobfuscation.
app/build/outputs/mapping/


# =============================================================================
# SECTION 3 — ANDROID STUDIO / IntelliJ IDEA IDE FILES
#
# The .idea/ directory contains a mix of safe project settings and
# machine-specific state. The strategy here is to exclude the entire directory
# and rely on the separate .idea/.gitignore (committed to git) to re-allow the
# small set of files that are safe and useful to share across the team:
#   - .idea/.gitignore, .idea/.name
#   - .idea/codeStyles/, .idea/inspectionProfiles/
#   - .idea/compiler.xml, .idea/gradle.xml, .idea/misc.xml, .idea/vcs.xml
#
# Machine-specific files that must NOT be committed include:
#   - workspace.xml (editor layout, breakpoints, window positions)
#   - deploymentTargetSelector.xml (contains absolute AVD path like C:\Users\...)
#   - appInsightsSettings.xml (machine telemetry config)
#   - AndroidProjectSystem.xml (regenerated on every sync)
#   - deviceManager.xml (local device/emulator list)
#   - runConfigurations.xml (run state, not shared configs)
#   - migrations.xml (IDE-internal migration tracking)
# =============================================================================

# Exclude the entire .idea/ directory. The .idea/.gitignore file (committed)
# handles the fine-grained re-allows for team-shared settings.
.idea/

# IntelliJ module descriptor files (contain machine-specific absolute paths).
*.iml

# IntelliJ workspace state file (editor tabs, window layout — machine-specific).
*.iws

# Android Studio captures directory (screenshots, method traces).
/captures/

# Android Studio / IntelliJ profiler heap dumps (large binary files).
*.hprof


# =============================================================================
# SECTION 4 — ROOM DATABASE & USER DATA
#
# Room schema export JSON files are auto-generated on every build — no need
# to commit them. Runtime database files are binary SQLite files that contain
# real user collection data. DataStore and SharedPreferences files may contain
# PII or user preferences. None of these belong in version control.
# =============================================================================

# Room schema export JSON files (auto-generated by KSP on each build).
app/schemas/

# SQLite runtime database files (binary, contain user MTG collection data).
*.db
*.db-journal
*.db-shm
*.db-wal

# Android SharedPreferences XML files (may contain user tokens or settings).
shared_prefs/

# Jetpack DataStore binary files (user_prefs DataStore — potentially PII).
datastore/


# =============================================================================
# SECTION 5 — LOGS & CRASH REPORTS
#
# Log files may contain stack traces, user data, device identifiers, or
# full API responses. Crash dumps can expose memory contents.
# None of these should ever be committed.
# =============================================================================

# General log files.
*.log
*.txt.log

# Android logcat text captures saved to disk.
logcat_*.txt

# Crashlytics and Firebase local build intermediates.
# These contain app IDs and Crashlytics mapping metadata.
app/build/intermediates/crashlytics/
app/build/intermediates/gmpAppId/

# Test result reports generated by JUnit and Android instrumented tests.
# Publish these to a CI artifact store (e.g., GitHub Actions artifacts), not git.
app/build/reports/
app/build/test-results/
app/build/outputs/logs/


# =============================================================================
# SECTION 6 — CI/CD & DEPLOYMENT SECRETS
#
# Environment files and CI configuration artifacts may contain signing
# passwords, Firebase service account JSON, or deployment tokens.
# Protect all of them regardless of whether they exist today.
# =============================================================================

# Firebase service account keys (used for CI deployment or Firebase Admin SDK).
# These grant admin access to your Firebase project — treat like a password.
service-account.json
firebase-adminsdk*.json
*-service-account.json

# Fastlane credentials, session cookies, and generated reports.
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/
fastlane/test_output/
fastlane/.env*

# Any locally stored tokens or credential files.
.secrets/
*.token
*.credential


# =============================================================================
# SECTION 7 — OPERATING SYSTEM FILES
#
# Metadata files generated automatically by macOS, Windows, and Linux.
# These are never useful in a shared repository and create noise in diffs.
# =============================================================================

# macOS Finder metadata and extended attributes.
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride

# Windows Explorer metadata, thumbnail cache, and shortcut files.
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux trash and temporary filesystem artifacts.
.fuse_hidden*
.directory
.Trash-*
.nfs*


# =============================================================================
# SECTION 8 — CLAUDE CODE AGENT MEMORY & LOCAL CONFIGURATION
#
# The .claude/ directory contains AI agent memory files with architectural
# decisions, detected vulnerabilities, and project-specific security analysis.
# This is local development tooling — agent memory must never be committed
# to version control because it may contain sensitive findings or internal notes.
#
# Exception: .claude/settings.json (shared team configuration) MAY be committed
# if your team explicitly decides to share Claude Code project settings.
# settings.local.json is always personal and must never be committed.
# =============================================================================

# Agent memory files (security analysis, architecture notes, AI context).
.claude/agent-memory/

# Agent definition files (prompt engineering — keep local or in a private repo).
.claude/agents/

# Agent workspace directories at repository root — ephemeral, never commit.
.agents/
.codex/

# Local Claude Code settings overrides (personal, machine-specific).
.claude/settings.local.json

# Git worktrees created by Claude Code agents — ephemeral, never commit.
.claude/worktrees/

# AI agent task-planning documents — ephemeral, never commit.
# These are intermediate files created by Claude/LLMs during task execution.
# They are deleted when the task is finished and must NEVER contain secrets.
# Pattern covers common naming conventions: *_TODO.md, *_PLAN.md, PLAN_*.md, PLAN.md
# at any depth. Proper design docs (ADRs, RFCs) live under docs/adr/ and ARE committed.
docs/*_TODO.md
docs/*_PLAN.md
docs/PLAN_*.md
docs/PLAN.md
*_TODO.md
PLAN.md
# Catch-all for agent scratchpad files at repo root
TASK_*.md


# =============================================================================
# SECTION 9 — TOOLS / COLLATION SCRIPT OUTPUTS
#
# build-booster.mjs generates booster.json files from MTGJSON data.
# These are uploaded to Cloudflare R2 out-of-band and must not be committed.
# =============================================================================

tools/collation/output/
NOTES_*.md

# Python draft pipeline (scripts/draftsim_py): generated artifacts + intermediate
# downloads are uploaded to R2 out-of-band and must not be committed.
scripts/draftsim_py/output/
scripts/draftsim_py/.cache/
scripts/draftsim_py/__pycache__/
scripts/draftsim_py/**/__pycache__/


# =============================================================================
# SECTION 9 — MISCELLANEOUS GENERATED FILES
#
# Files generated by build tooling, Kotlin compilation, or IDE indexing
# that are fully reproducible and should not be tracked.
# =============================================================================

# Kotlin incremental compilation session data (fully regenerated each build).
.kotlin/

# Android lint baseline file.
# POLICY DECISION — choose one approach and uncomment the appropriate line:
#   Option A: Commit the baseline to track which lint issues are accepted waivers.
#             (Leave the line below commented — do NOT ignore lint-baseline.xml)
#   Option B: Treat all lint warnings as must-fix; never commit a baseline.
#             Uncomment the line below to prevent accidental baseline commits.
# lint-baseline.xml

# =============================================================================
# SECTION 10 — GRAPHIFY KNOWLEDGE GRAPH (LOCAL ONLY)
#
# The graphify-out/ directory contains the local knowledge graph of the
# codebase: graph.json (11 MB), graph.html (9 MB), GRAPH_REPORT.md (110 KB),
# extraction cache, and community labels. This is machine-specific tooling —
# the graph is rebuilt locally via the post-commit hook or /graphify --update.
# Never commit these files; they are large, binary-ish, and local-only.
# =============================================================================

graphify-out/

# =============================================================================
# END OF .gitignore
