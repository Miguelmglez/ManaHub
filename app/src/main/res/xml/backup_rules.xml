<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <exclude domain="file" path="datastore/" />
    <exclude domain="database" path="." />
    <!-- Exclude all SharedPreferences — includes Supabase session tokens -->
    <exclude domain="sharedpref" path="." />
    <!-- Exclude Supabase session DataStore (auth token, refresh token) -->
    <exclude domain="file" path="datastore/supabase_session.preferences_pb" />
    <!-- Exclude Crashlytics pending crash reports from backup -->
    <exclude domain="file" path=".firebase" />
    <!-- Exclude downloaded card hash database — large binary, reconstructed on demand -->
    <exclude domain="file" path="card_hashes.bin" />
    <exclude domain="file" path="card_hashes.bin.tmp" />
    <!-- Exclude per-set draft guide and tier-list JSON cache — refetched from Cloudflare on demand -->
    <exclude domain="file" path="draft/" />
</full-backup-content>
