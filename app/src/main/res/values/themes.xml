<resources>
    <style name="Theme.ManaHub" parent="Theme.SplashScreen">
        <!-- Splash screen icon background (deep dark, matching NeonVoid) -->
        <item name="windowSplashScreenBackground">#0A0A14</item>
        <!-- Splash screen icon — uses the app launcher icon -->
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <!-- Theme to switch to once splash is done -->
        <item name="postSplashScreenTheme">@style/Theme.ManaHub.App</item>
    </style>

    <style name="Theme.ManaHub.App" parent="android:Theme.Material.Light.NoActionBar" />
</resources>
