  "set_overview": {
    "summary": "Streets of New Capenna features five three-color crime families, each with distinct mechanics. Most decks play as a 2-color base plus a splash into an adjacent family's gold cards. Inspiring Overseer is the best common in the set.",
    "color_ranking": [
      "Best pair: Azorius (WU) — Inspiring Overseer engine",
      "Strong pairs: Dimir (UB), Selesnya (GW), Gruul (RG)",
      "Weak pair: Rakdos (BR) — red generally underperforms"
    ],
    "color_notes": {
      "Note": "SNC is family-driven (5 three-color clans). Most decks start as a 2-color base (ally pair) and splash adjacent family gold cards via dual lands."
    },
    "key_gameplay_notes": [
      "Find primary two-color lane first; solidify with gold cards from adjacent families.",
      "Splash bombs via dual lands and fixing.",
      "Priority: top commons → removal → curve → dual lands.",
      "Track multicolor cards as signal indicators.",
      "Inspiring Overseer is worth most commons and several rares."
    ]
  },
  "mechanics": [
    {
      "name": "Alliance (Cabaretti)",
      "summary": "Landfall for creatures — triggers when creatures enter the battlefield under your control. Rewards keeping many creatures in play.",
      "performance": "Easy to enable in token / go-wide decks.",
      "key_examples": []
    },
    {
      "name": "Blitz (Riveteers)",
      "summary": "Play creatures with haste; sacrifice them at end of turn and draw a card. Functions as cantripping removal when opponents avoid trading.",
      "performance": "Reliable; the bonus is built into every Blitz creature.",
