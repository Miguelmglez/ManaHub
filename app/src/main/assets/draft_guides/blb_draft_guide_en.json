  "set_overview": {
    "summary": "Bloomburrow received mixed reception regarding pacing, color balance, and linearity, though the theming resonates well. The format features ten tribal archetypes with distinct mechanics supporting each color pair.",
    "color_ranking": [
      "{G} Green",
      "{W} White",
      "{B} Black",
      "{R} Red",
      "{U} Blue"
    ],
    "color_notes": {
      "{G} Green": "Best color. Superior creature sizing, removal, and mana-fixing enablement.",
      "{W} White": "Aggressive payoffs with premium removal (Banishing Light, Repel Calamity).",
      "{B} Black": "Strong removal suite and solid value creatures.",
      "{R} Red": "Aggressive color with good removal spells (Take Out the Trash, Agate Assault).",
      "{U} Blue": "Weakest common quality; best deployed as a support color."
    },
    "key_gameplay_notes": [
      "Carrot Cake addresses low consistency through scry effects and mana smoothing.",
      "Green depth at common exceeds other colors significantly.",
      "Token payoffs (Caretaker's Talent, Finneas, Ace Archer) need token generators — Carrot Cake is premium for that.",
      "The format skews toward aggressive strategies with limited sweeper availability."
    ]
  },
  "mechanics": [
    {
      "name": "Offspring",
      "summary": "Creates token copies of creatures. Uneven power level overall; the standouts are clear (Intrepid Rabbit is the headliner).",
      "performance": "Variable. Build around the strongest Offspring cards rather than treating it as a primary theme.",
      "key_examples": [
        {
          "name": "Intrepid Rabbit",
          "color": "W",
          "rarity": "Common",
          "pick_order_rank": 59,
          "tier_rating": "A",
          "note": null,
          "id": "4d70b99d-c8bf-4a56-8957-cf587fe60b81",
          "scryfall_uri": "https://scryfall.com/card/blb/17/intrepid-rabbit",
          "colors": [
            "W"
          ],
          "type_line": "Creature — Rabbit Soldier",
          "image_uris": {
            "art_crop": "https://cards.scryfall.io/art_crop/front/4/d/4d70b99d-c8bf-4a56-8957-cf587fe60b81.jpg?1721425856",
            "normal": "https://cards.scryfall.io/normal/front/4/d/4d70b99d-c8bf-4a56-8957-cf587fe60b81.jpg?1721425856"
          },
          "set": "blb",
          "set_name": "Bloomburrow"
        }
      ]
    },
    {
      "name": "Valiant",
      "summary": "Mouse-specific trigger that activates when the creature is targeted by your own spell. Primarily matters in Boros (RW) Mice.",
      "performance": "Core to RW; situational elsewhere.",
      "key_examples": []
    },
    {
      "name": "Forage",
      "summary": "Graveyard-fueled mechanic — exile cards from your graveyard for a payoff. Excellent in Golgari (BG) Squirrels.",
      "performance": "Engine of tier-1 BG Squirrels.",
      "key_examples": []
    },
    {
      "name": "Expend",
      "summary": "Straightforward mechanic triggered when you spend four or more mana in a turn. Any deck can utilize the four-drop synergies.",
      "performance": "Flexible. Works in nearly every archetype.",
      "key_examples": []
    },
    {
      "name": "Gift",
      "summary": "Opponent-choice interaction where you offer a benefit to the opponent in exchange for extra value. Encourages interesting decision-making.",
      "performance": "Niche. Strong when you can make the gift irrelevant.",
      "key_examples": []
    },
    {
      "name": "Pawprint / Seasons",
      "summary": "Modular payoff cards that scale with pawprint counts. Season of the Bold underperforms slightly compared to the rest.",
      "performance": "Best in dedicated tribal decks that pile pawprints on a single threat.",
      "key_examples": []
    },
    {
      "name": "Threshold",
      "summary": "Seven-cards-in-graveyard condition. Creates setup cost for the Rats archetype.",
      "performance": "Slow to enable; needs heavy mill/discard support.",
      "key_examples": []
    },
    {
      "name": "Changeling",
      "summary": "Counts as every creature type. Better in Sealed than Draft due to splash requirements.",
      "performance": "Sealed staples; weaker in Draft.",
      "key_examples": []
    }
  ],
