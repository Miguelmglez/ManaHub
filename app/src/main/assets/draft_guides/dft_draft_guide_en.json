  "set_overview": {
    "summary": "Aetherdrift is a flawed Limited format with significant balance issues. Color balance is very bad, common cards are weak, vehicles underperform despite the set's theme, and board stalls dominate gameplay. The format rewards understanding these problems rather than avoiding them.",
    "color_ranking": [
      "{G} Green",
      "{B} Black",
      "{U} Blue",
      "{R} Red",
      "{W} White"
    ],
    "color_notes": {
      "{G} Green": "Deepest color with excellent commons (Stampeding Scurryfoot, Run Over, Migrating Ketradon). Sets the ceiling for creature size.",
      "{B} Black": "Only slightly behind green. Strong removal answers across the rarity spectrum.",
      "{U} Blue": "Solid commons but more fragile. Benefits from strong payoffs to convert tempo into wins.",
      "{R} Red": "Two excellent commons (Thunderhead Gunner, Lightning Strike) but struggles against green fatties.",
      "{W} White": "King of bad filler — tiny creatures and weak removal at common."
    },
    "key_gameplay_notes": [
      "Board stalls are the default — card advantage and mana sinks become crucial late.",
      "\"Almost everything you'd need dead dies to\" Spin Out — premium black removal.",
      "Speed (\"Start Your Engines!\") is all-or-nothing: commit heavily or skip entirely.",
      "Cycling doesn't justify reducing land counts below 16.",
      "Budget for 3-5 vehicles maximum in most decks; common vehicles are among the weakest cards in the format.",
      "Splashing works when bombs justify it; most color-fixing vehicles are undesirable standalone."
    ]
  },
  "mechanics": [
    {
      "name": "Speed (\"Start Your Engines!\")",
      "summary": "Three card types exist: those requiring maximum speed to function (Hazoret Godseeker), enablers that work reasonably alone (the Surveyor cycle), and weak cards only playable with payoffs. Don't dabble — either commit heavily or skip entirely. Remember to play Speed creatures before attacking.",
      "performance": "All-or-nothing payoff theme. Defines BR Speed and feeds WB Speed.",
