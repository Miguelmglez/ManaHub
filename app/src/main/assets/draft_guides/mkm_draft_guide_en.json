  "metadata": {
    "set_name": "Murders at Karlov Manor",
    "set_code": "MKM",
    "source_url": "https://draftsim.com/the-ultimate-guide-to-murders-at-karlov-manor-draft/",
    "credit": "Data and analysis provided by Draftsim",
    "author": "Bryan Hohns (Veveil)",
    "last_updated": "February 16, 2024"
  },
  "set_overview": {
    "summary": "Murders at Karlov Manor is a medium-paced Limited format where blocking is challenging due to strong combat tricks and disguise mechanics. The set features excellent removal at uncommon/rare but lacks common sweepers, making go-wide strategies particularly effective.",
    "color_ranking": [
      "{W} White",
      "{R} Red",
      "{G} Green",
      "{U} Blue",
      "{B} Black"
    ],
    "color_notes": {
      "{W} White": "Best color. Top commons and creatures; excels at small creature strategies.",
      "{R} Red": "Efficient removal but weaker creature quality. Excellent support color.",
      "{G} Green": "Premium mana fixers enable 5-color strategies; solid creatures.",
      "{U} Blue": "Good creatures and tempo spells; weak removal and poor 2-drops.",
      "{B} Black": "Quality removal hindered by Ward 2 on disguise creatures; weak creatures."
    },
    "key_gameplay_notes": [
      "Format rewards tempo and aggressive strategies.",
      "Sweepers (No Witnesses, Deadly Cover-Up, Ill-Timed Explosion) are rares only.",
      "Combat tricks (Auspicious Arrival, The Chase Is On, On the Job) are exceptionally strong.",
      "Green's mana fixers (Tunnel Tipster, Loxodon Eavesdropper, Nervous Gardener) enable ambitious multicolor decks.",
      "Draft with tempo in mind; board states escalate quickly."
    ]
  },
  "mechanics": [
    {
      "name": "Disguise",
      "summary": "Morph variant with Ward 2; creatures often have \"turn face up\" effects on payoff.",
      "performance": "Format-defining. Ward 2 makes black removal less reliable against these creatures.",
      "key_examples": []
    },
    {
      "name": "Cloak",
      "summary": "Manifest variant with Ward 2; opponents can flip cloaked cards by paying the mana cost.",
      "performance": "Provides hidden information and tempo plays.",
      "key_examples": []
    },
    {
      "name": "Suspect",
      "summary": "Aggressive keyword that suspects opponents' creatures (gives them menace, prevents blocking). Limited impact on format — Rakdos archetype underperforms.",
      "performance": "Underperforms relative to design expectations.",
      "key_examples": []
    },
    {
      "name": "Collect Evidence",
      "summary": "Delve-style mechanic that exiles cards from your graveyard with combined mana value at least N. Works as an accessory or a build-around in Simic/Golgari.",
      "performance": "Solid value engine in graveyard-leaning decks.",
      "key_examples": []
    },
    {
      "name": "Cases",
      "summary": "Enchantments with three clauses that activate when an objective is solved. Quality varies widely; standouts include Case of the Gateway Express and Case of the Burning Masks.",
      "performance": "Best cases are fantastic; worst are unplayable.",
